{
  "name": "@thock/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build:manifest": "tsx scripts/generate-data-manifest.mts",
    "build:search": "tsx scripts/generate-search-index.mts",
    "prebuild": "pnpm build:manifest && pnpm build:search",
    "build": "next build",
    "start": "next start",
    "start:e2e": "next start -p 4173",
    "typecheck": "tsc --noEmit",
    "pretest:run": "pnpm build:manifest && pnpm build:search",
    "test": "vitest",
    "test:run": "vitest run",
    "size": "tsx scripts/measure-bundle.mts",
    "lint": "next lint"
  },
  "dependencies": {
    "@thock/content": "workspace:*",
    "@thock/data": "workspace:*",
    "@thock/seo": "workspace:*",
    "@thock/tokens": "workspace:*",
    "@thock/ui": "workspace:*",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "minisearch": "^7.2.0",
    "next": "^15.0.3",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@thock/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
