{
  "$ref": "#/definitions/vendor",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "vendor": {
      "additionalProperties": false,
      "properties": {
        "countryCode": {
          "pattern": "^[A-Z]{2}$",
          "type": "string"
        },
        "description": {
          "maxLength": 600,
          "minLength": 20,
          "type": "string"
        },
        "name": {
          "minLength": 2,
          "type": "string"
        },
        "slug": {
          "minLength": 2,
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "type": "string"
        },
        "status": {
          "enum": [
            "active",
            "inactive"
          ],
          "type": "string"
        },
        "updatedAt": {
          "format": "date-time",
          "type": "string"
        },
        "url": {
          "format": "uri",
          "type": "string"
        }
      },
      "required": [
        "slug",
        "name",
        "url",
        "countryCode",
        "description",
        "status",
        "updatedAt"
      ],
      "type": "object"
    }
  }
}
