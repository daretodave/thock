{
  "$ref": "#/definitions/keycap-set",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "keycap-set": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "maxLength": 800,
          "minLength": 20,
          "type": "string"
        },
        "designer": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "imageUrl": {
          "anyOf": [
            {
              "format": "uri",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "legendType": {
          "enum": [
            "doubleshot",
            "dye-sub",
            "pad-printed",
            "engraved",
            "blank"
          ],
          "type": "string"
        },
        "material": {
          "enum": [
            "abs",
            "pbt",
            "resin",
            "mixed"
          ],
          "type": "string"
        },
        "name": {
          "minLength": 2,
          "type": "string"
        },
        "profile": {
          "enum": [
            "cherry",
            "oem",
            "mt3",
            "sa",
            "kat",
            "kam",
            "xda",
            "dsa"
          ],
          "type": "string"
        },
        "releasedAt": {
          "anyOf": [
            {
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "slug": {
          "minLength": 2,
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "type": "string"
        },
        "status": {
          "enum": [
            "in-stock",
            "sold-out",
            "group-buy",
            "discontinued"
          ],
          "type": "string"
        },
        "updatedAt": {
          "format": "date-time",
          "type": "string"
        },
        "vendorSlug": {
          "$ref": "#/definitions/keycap-set/properties/slug"
        }
      },
      "required": [
        "slug",
        "name",
        "vendorSlug",
        "profile",
        "material",
        "legendType",
        "designer",
        "releasedAt",
        "status",
        "imageUrl",
        "description",
        "updatedAt"
      ],
      "type": "object"
    }
  }
}
