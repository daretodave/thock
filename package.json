{
  "name": "thock",
  "version": "0.0.0",
  "private": true,
  "description": "thock — keyboards, deeply. Editorial content hub for mechanical keyboard enthusiasts.",
  "homepage": "https://thock.xyz",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @thock/web dev",
    "build": "pnpm --filter @thock/web build",
    "start": "pnpm --filter @thock/web start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --no-bail test",
    "test:run": "pnpm -r --no-bail test:run",
    "e2e": "pnpm --filter @thock/e2e e2e",
    "e2e:install": "pnpm --filter @thock/e2e e2e:install",
    "lint": "pnpm -r --no-bail lint",
    "format": "prettier --write .",
    "data:validate": "pnpm --filter @thock/data validate",
    "test:scripts": "node --test scripts/__tests__/*.mjs",
    "size": "pnpm --filter @thock/web size",
    "verify": "pnpm typecheck && pnpm test:run && pnpm test:scripts && pnpm data:validate && pnpm build && pnpm size && pnpm e2e",
    "deploy:check": "node scripts/deploy-check.mjs",
    "deploy:smoke": "node scripts/deploy-smoke.mjs"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.28.1": ">=0.28.1",
      "postcss@<8.5.10": ">=8.5.10",
      "vite": "^6.4.3",
      "vitest@<3.2.6": ">=3.2.6 <4.0.0",
      "form-data@<4.0.6": ">=4.0.6",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "js-yaml@<3.15.0": "3.15.0",
      "js-yaml@>=4.0.0 <=4.1.1": "4.3.0",
      "@babel/core@<=7.29.0": "7.29.7",
      "brace-expansion@>=3.0.0 <5.0.7": ">=5.0.7",
      "brace-expansion@<1.1.16": ">=1.1.16",
      "sharp@<0.35.0": ">=0.35.0"
    }
  }
}
