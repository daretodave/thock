{
  "name": "thock",
  "version": "0.0.0",
  "private": true,
  "description": "thock — keyboards, deeply. Editorial content hub for mechanical keyboard enthusiasts.",
  "homepage": "https://thock.netlify.app",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @thock/web dev",
    "build": "pnpm --filter @thock/web build",
    "start": "pnpm --filter @thock/web start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --no-bail test",
    "test:run": "pnpm -r --no-bail test:run",
    "e2e": "pnpm --filter @thock/e2e e2e",
    "e2e:install": "pnpm --filter @thock/e2e e2e:install",
    "lint": "pnpm -r --no-bail lint",
    "format": "prettier --write .",
    "data:validate": "pnpm --filter @thock/data validate",
    "verify": "pnpm typecheck && pnpm test:run && pnpm data:validate && pnpm build && pnpm e2e",
    "deploy:check": "node scripts/deploy-check.mjs"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
