# Copy this file to .env and fill in the value.
# .env is gitignored; never commit it.

# Netlify personal access token, used by `pnpm deploy:check`.
# Get one at https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=

# Site name on Netlify. Defaults to "thock". Override only if running
# the loop against a different site.
# NETLIFY_SITE_NAME=thock
