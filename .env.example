# Copy this file to .env and fill in the values.
# .env is gitignored; never commit it.

# Vercel personal access token, used by `pnpm deploy:check`.
# Get one at https://vercel.com/account/tokens
VERCEL_TOKEN=

# Vercel project name. Defaults to "thock" (the canonical project
# name — the public alias is thock-coral.vercel.app).
# VERCEL_PROJECT_NAME=thock

# Vercel team ID. Required for this repo because the project lives
# under a team scope rather than a personal account. Get it via
# `curl -H "Authorization: Bearer <token>" https://api.vercel.com/v2/teams`
# VERCEL_TEAM_ID=team_...

# GitHub personal access token for /triage (the issue review loop).
# Needs: repo scope (read + write issues, comments, labels).
# Fine-grained PAT scoped to the thock repo is sufficient.
# Get one at https://github.com/settings/tokens
# gh CLI auto-reads GH_TOKEN.
GH_TOKEN=

# Repo slug for /triage. Defaults to "daretodave/thock" if unset.
# Override if running the loop against a fork.
# GH_REPO=daretodave/thock
